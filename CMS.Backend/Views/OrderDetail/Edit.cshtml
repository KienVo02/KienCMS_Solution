@model CMS.Data.Entities.OrderDetail

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <h2 class="text-warning">
        CHỈNH SỬA CHI TIẾT ĐƠN HÀNG
    </h2>

    <hr />

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">

            <label class="form-label fw-bold">
                Đơn hàng:
            </label>

            <select asp-for="OrderId"
                    asp-items="ViewBag.Orders"
                    class="form-select">

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label fw-bold">
                Sản phẩm:
            </label>

            <select asp-for="ProductId"
                    asp-items="ViewBag.Products"
                    class="form-select">

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label fw-bold">
                Số lượng:
            </label>

            <input asp-for="Quantity"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label class="form-label fw-bold">
                Đơn giá:
            </label>

            <input asp-for="UnitPrice"
                   class="form-control" />

        </div>

        <button type="submit"
                class="btn btn-warning">
            Cập nhật
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Hủy
        </a>

    </form>

</div>