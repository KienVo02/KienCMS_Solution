@model CMS.Data.Entities.Product

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <h2 class="text-warning">
        CHỈNH SỬA SẢN PHẨM
    </h2>

    <hr />

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="mb-3">
            <label class="form-label fw-bold">
                Tên sản phẩm:
            </label>

            <input asp-for="Name" class="form-control" />

            <span asp-validation-for="Name"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                Mô tả:
            </label>

            <textarea asp-for="Description"
                      class="form-control"
                      rows="3"></textarea>

            <span asp-validation-for="Description"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                Giá:
            </label>

            <input asp-for="Price"
                   class="form-control" />

            <span asp-validation-for="Price"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                Số lượng:
            </label>

            <input asp-for="StockQuantity"
                   class="form-control" />

            <span asp-validation-for="StockQuantity"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                Hình ảnh hiện tại:
            </label>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                    <div class="mb-2">
                        <img src="@Model.ImageUrl"
                             alt="@Model.Name"
                             style="width: 180px; height: 110px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                    </div>
            }
            else
            {
                    <p class="text-muted">
                        Sản phẩm chưa có hình ảnh.
                    </p>
            }

            <input type="file"
                   name="imageFile"
                   class="form-control"
                   accept="image/*" />

            <small class="text-muted">
                Nếu không chọn ảnh mới, hệ thống sẽ giữ nguyên ảnh cũ.
            </small>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                ID Danh mục:
            </label>

            <input asp-for="CategoryProductId"
                   class="form-control" />

            <span asp-validation-for="CategoryProductId"
                  class="text-danger"></span>
        </div>

        <button type="submit"
                class="btn btn-warning">
            Cập nhật
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Hủy
        </a>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}