@model CMS.Data.Entities.Product

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <h2 class="text-success">
        THÊM SẢN PHẨM
    </h2>

    <hr />

    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label class="form-label fw-bold">
                Tên sản phẩm:
            </label>

            <input asp-for="Name" class="form-control" />

            <span asp-validation-for="Name"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                Mô tả:
            </label>

            <textarea asp-for="Description"
                      class="form-control"
                      rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                Giá:
            </label>

            <input asp-for="Price"
                   class="form-control" />

            <span asp-validation-for="Price"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                Số lượng:
            </label>

            <input asp-for="StockQuantity"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                Hình ảnh:
            </label>

            <input asp-for="ImageUrl"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">
                ID Danh mục:
            </label>

            <input asp-for="CategoryProductId"
                   class="form-control" />
        </div>

        <button type="submit"
                class="btn btn-success">
            Thêm mới
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Quay lại
        </a>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}