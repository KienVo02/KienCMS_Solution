@model List<CMS.Data.Entities.Product>

<h2>Danh sách sản phẩm</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tên sản phẩm</th>
            <th>Mô tả</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Hình ảnh</th>
            <th>Danh mục</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.Id</td>

                    <td>@item.Name</td>

                    <td>@item.Description</td>

                    <td>@item.Price VNĐ</td>

                    <td>@item.StockQuantity</td>

                    <td>
                        <img src="@item.ImageUrl"
                             width="120" />
                    </td>

                    <td>
                    @item.CategoryProduct?.Name
                    </td>
                </tr>
        }
    </tbody>
</table>