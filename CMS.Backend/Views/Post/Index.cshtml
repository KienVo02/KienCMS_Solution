@model List<CMS.Data.Entities.Post>

<h2>Danh sách bài viết</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tiêu đề</th>
            <th>Nội dung</th>
            <th>Hình ảnh</th>
            <th>Ngày tạo</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Title</td>
                    <td>@item.Content</td>
                    <td>
                        <img src="@item.ImageUrl"
                             width="120" />
                    </td>
                    <td>@item.CreatedDate</td>
                </tr>
        }
    </tbody>
</table>