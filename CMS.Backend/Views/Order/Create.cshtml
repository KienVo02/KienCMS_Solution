@model CMS.Data.Entities.Order

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <h2 class="text-success">
        THÊM ĐƠN HÀNG
    </h2>

    <hr />

    <form asp-action="Create" method="post">

        <div class="mb-3">

            <label class="form-label fw-bold">
                Khách hàng:
            </label>

            <select asp-for="CustomerId"
                    asp-items="ViewBag.Customers"
                    class="form-select">

                <option value="">
                    -- Chọn khách hàng --
                </option>

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label fw-bold">
                Trạng thái:
            </label>

            <select asp-for="Status" class="form-select">

                <option value="0">
                    Chờ duyệt
                </option>

                <option value="1">
                    Đang giao
                </option>

                <option value="2">
                    Đã xong
                </option>

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label fw-bold">
                Ghi chú:
            </label>

            <textarea asp-for="Notes"
                      class="form-control"
                      rows="3"></textarea>

        </div>

        <button type="submit"
                class="btn btn-success">
            Thêm mới
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Quay lại
        </a>

    </form>

</div>